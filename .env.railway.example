# ─── Railway Environment Variables ───────────────────────────────────────────
# Copy this file to .env.railway and fill in real values.
# Generate it automatically with: python scripts/extract_railway_env.py
#
# Railway provides DATABASE_URL automatically when a Postgres plugin is attached.
# All OAuth refresh tokens are extracted from local JSON token files.

# ─── Database (auto-set by Railway Postgres plugin) ──────────────────────────
DATABASE_URL=postgresql://...

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Pipedrive ───────────────────────────────────────────────────────────────
PIPEDRIVE_API_TOKEN=
PIPEDRIVE_BASE_URL=https://api.pipedrive.com/v1

# ─── Jobber (OAuth 2.0) ───────────────────────────────────────────────────────
# Client credentials (from Jobber developer portal)
JOBBER_CLIENT_ID=
JOBBER_CLIENT_SECRET=
# Refresh token extracted from .jobber_tokens.json by extract_railway_env.py
JOBBER_REFRESH_TOKEN=
JOBBER_API_VERSION=2026-03-10
JOBBER_BASE_URL=https://api.getjobber.com/api/graphql

# ─── QuickBooks Online (OAuth 2.0) ───────────────────────────────────────────
# Client credentials (from Intuit developer portal)
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
# Refresh token extracted from .quickbooks_tokens.json by extract_railway_env.py
QUICKBOOKS_REFRESH_TOKEN=
QBO_COMPANY_ID=
QBO_BASE_URL=https://sandbox-quickbooks.api.intuit.com/v3/company

# ─── Google Workspace (OAuth 2.0) ─────────────────────────────────────────────
# Client credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Refresh token extracted from token.json by extract_railway_env.py
GOOGLE_REFRESH_TOKEN=
# Scopes granted: drive, documents, spreadsheets, calendar, gmail.readonly

# ─── HubSpot ─────────────────────────────────────────────────────────────────
HUBSPOT_ACCESS_TOKEN=pat-na2-...
HUBSPOT_BASE_URL=https://api.hubapi.com

# ─── Mailchimp ───────────────────────────────────────────────────────────────
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=us4
MAILCHIMP_LIST_ID=

# ─── Asana ───────────────────────────────────────────────────────────────────
ASANA_ACCESS_TOKEN=
ASANA_WORKSPACE_GID=
ASANA_TEAM_GID=
ASANA_PROJECT_SALES_PIPELINE_GID=
ASANA_PROJECT_MARKETING_CALENDAR_GID=
ASANA_PROJECT_ADMIN_OPERATIONS_GID=
ASANA_PROJECT_CLIENT_SUCCESS_GID=

# ─── Slack ───────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_WORKSPACE_ID=
SLACK_CHANNEL_GENERAL=
SLACK_CHANNEL_SALES=
SLACK_CHANNEL_SALES_PIPELINE=
SLACK_CHANNEL_OPERATIONS=
SLACK_CHANNEL_DAILY_BRIEFING=
SLACK_CHANNEL_NEW_CLIENTS=
SLACK_CHANNEL_REVIEWS_AND_FEEDBACK=
SLACK_CHANNEL_SOCIAL=
SLACK_CHANNEL_ALL=
